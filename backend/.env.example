APP_NAME="SaaS Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Central database (tenant registry, users, plans, billing) ───
# Tenant databases are provisioned automatically per organization.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=saas_central
DB_USERNAME=saas
DB_PASSWORD=secret

# Tenant DB naming: databases are created as `${TENANT_DB_PREFIX}<uuid>`
TENANT_DB_PREFIX=tenant_
TENANT_DB_SUFFIX=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Send session cookies over HTTPS only. Must be true in production (HTTPS-only);
# leave false for plain-http local dev or the cookie never reaches the browser.
SESSION_SECURE_COOKIE=true

# Sanctum SPA / token auth
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
# Minutes until an issued API token expires. 20160 = 14 days.
SANCTUM_EXPIRATION=20160

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# Must support tagging: tenancy tags cache entries per organization, which
# the file and database drivers cannot do. redis | memcached only.
CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@saas.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Billing (Stripe) ───
# Price ids differ between Stripe's test and live catalogues. Read via
# config/billing.php, never env() at point of use — `config:cache` in production
# makes env() return null outside config, which would silently strip the price
# from every paid plan.
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=usd

STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

BILLING_TRIAL_DAYS=14

# ─── Social login (Phase 2) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/social/google/callback"
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/api/v1/auth/social/github/callback"

# ─── Telescope / Horizon ───
TELESCOPE_ENABLED=true

# Set true in local dev to regenerate API docs on each request; keep false in
# production and run `php artisan l5-swagger:generate` at deploy time.
L5_SWAGGER_GENERATE_ALWAYS=false
