# Base URL of the Laravel API (no trailing slash). The client appends /api.
VITE_API_URL=http://localhost:8000

# App metadata
VITE_APP_NAME="SaaS Platform"

# Stripe publishable key (pk_test_… / pk_live_…). Safe to ship to the browser by
# design; it is what Stripe.js uses to tokenize a card. Leave blank to hide the
# card form — the app degrades to "card payments are not configured".
VITE_STRIPE_KEY=
